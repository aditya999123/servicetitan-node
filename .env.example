# Copy this file to .env and fill in your real ServiceTitan credentials.
# .env is gitignored — never commit real credentials.

SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=
SERVICETITAN_APP_KEY=
SERVICETITAN_TENANT_ID=

# "integration" or "production" — defaults to "integration" if unset.
# Use "integration" unless you specifically intend to hit production data.
SERVICETITAN_ENVIRONMENT=integration
